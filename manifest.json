<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1, user-scalable=no">
<title>Drenagem Mineração — Dimensionamento Hidráulico</title>
<meta name="description" content="Dimensionamento de canais, tubos corrugados, bacias de sedimentação e dissipadores de energia para mineração a céu aberto">
<meta name="theme-color" content="#0F6E56">
<link rel="manifest" href="manifest.json">
<link rel="icon" href="icons/icon-192.png">
<link rel="apple-touch-icon" href="icons/icon-192.png">
<style>
:root{
  --bg-page:#F1EFE8;
  --surface-2:#ffffff;
  --surface-1:#F7F6F1;
  --border:#D3D1C7;
  --border-strong:#B4B2A9;
  --text-primary:#2C2C2A;
  --text-secondary:#5F5E5A;
  --text-muted:#888780;
  --accent:#0F6E56;
  --accent-bg:#E1F5EE;
  --accent-strong:#085041;
  --warn-bg:#FAEEDA;--warn-text:#854F0B;--warn-border:#FAC775;
  --err-bg:#FCEBEB;--err-text:#A32D2D;--err-border:#F09595;
  --ok-bg:#EAF3DE;--ok-text:#3B6D11;--ok-border:#C0DD97;
  --radius:8px;
}
*{box-sizing:border-box;margin:0;padding:0}
body{
  font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;
  background:var(--bg-page);
  color:var(--text-primary);
  padding-bottom:2rem;
  -webkit-font-smoothing:antialiased;
}
header{
  background:var(--accent);
  color:#fff;
  padding:1.1rem 1rem;
  position:sticky;top:0;z-index:50;
  box-shadow:0 1px 3px rgba(0,0,0,.08);
}
header h1{font-size:17px;font-weight:600;line-height:1.3}
header p{font-size:12px;opacity:.85;margin-top:2px}
.wrap{max-width:720px;margin:0 auto;padding:0 1rem}
.module-nav{
  display:flex;gap:6px;overflow-x:auto;padding:.75rem 1rem;
  background:var(--surface-2);border-bottom:0.5px solid var(--border);
  position:sticky;top:64px;z-index:40;-webkit-overflow-scrolling:touch;
}
.module-nav::-webkit-scrollbar{display:none}
.mtab{
  flex-shrink:0;padding:8px 14px;font-size:13px;font-weight:500;
  border-radius:20px;border:0.5px solid var(--border);background:var(--surface-1);
  color:var(--text-secondary);cursor:pointer;white-space:nowrap;
  display:flex;align-items:center;gap:5px;
}
.mtab.active{background:var(--accent);color:#fff;border-color:var(--accent)}
.panel{display:none;padding:1.25rem 1rem}
.panel.active{display:block}
.grid2{display:grid;grid-template-columns:1fr;gap:14px}
@media(min-width:720px){.grid2{grid-template-columns:1fr 1fr}}
.card{background:var(--surface-2);border:0.5px solid var(--border);border-radius:12px;padding:1rem 1.1rem;margin-bottom:12px}
.ctitle{font-size:11px;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:10px}
.field{margin-bottom:11px}
.field label{display:block;font-size:13px;color:var(--text-secondary);margin-bottom:4px}
.field input,.field select,.field textarea{
  width:100%;padding:9px 11px;border:0.5px solid var(--border);border-radius:var(--radius);
  font-size:15px;background:var(--surface-1);color:var(--text-primary);font-family:inherit;
}
.field input:focus,.field select:focus,.field textarea:focus{outline:none;border-color:var(--accent);box-shadow:0 0 0 2px var(--accent-bg)}
.btn{
  width:100%;padding:11px;font-size:14px;font-weight:600;border:0.5px solid var(--border-strong);
  border-radius:var(--radius);cursor:pointer;background:var(--surface-1);color:var(--text-primary);
  margin-top:8px;display:flex;align-items:center;justify-content:center;gap:6px;
}
.btn:active{transform:scale(0.98)}
.btn.primary{background:var(--accent);color:#fff;border-color:var(--accent)}
.section-title{font-size:16px;font-weight:600;margin-bottom:12px;margin-top:0}
.rg{display:grid;grid-template-columns:repeat(2,1fr);gap:8px;margin-top:10px}
@media(min-width:480px){.rg{grid-template-columns:repeat(auto-fit,minmax(130px,1fr))}}
.met{background:var(--surface-1);border-radius:var(--radius);padding:.7rem .9rem}
.ml{font-size:11.5px;color:var(--text-muted);margin-bottom:3px}
.mv{font-size:19px;font-weight:600;color:var(--text-primary)}
.mu{font-size:11.5px;color:var(--text-secondary);margin-left:2px;font-weight:400}
.al{padding:10px 13px;border-radius:var(--radius);font-size:13.5px;margin-top:10px;border:0.5px solid;line-height:1.55}
.ai{background:var(--accent-bg);border-color:#9FE1CB;color:var(--accent-strong)}
.aw{background:var(--warn-bg);border-color:var(--warn-border);color:var(--warn-text)}
.ae{background:var(--err-bg);border-color:var(--err-border);color:var(--err-text)}
.as{background:var(--ok-bg);border-color:var(--ok-border);color:var(--ok-text)}
table.res{width:100%;font-size:13.5px;border-collapse:collapse;margin-top:10px}
table.res th{font-size:11px;font-weight:600;color:var(--text-muted);text-align:left;padding:5px 6px;border-bottom:0.5px solid var(--border)}
table.res td{padding:6px 6px;border-bottom:0.5px solid var(--border)}
table.res tr:last-child td{border-bottom:none}
.highlight-row td{background:var(--accent-bg);color:var(--accent-strong);font-weight:600}
.badge{display:inline-block;padding:2px 9px;border-radius:12px;font-size:11.5px;font-weight:600}
.b-ok{background:var(--ok-bg);color:var(--ok-text)}.b-warn{background:var(--warn-bg);color:var(--warn-text)}.b-err{background:var(--err-bg);color:var(--err-text)}
.info{font-size:11.5px;color:var(--text-muted);margin-top:4px;line-height:1.4}
.divider{border:none;border-top:0.5px solid var(--border);margin:1rem 0}
svg.diagram{width:100%;margin-top:12px}
.install-banner{
  display:none;background:var(--accent-bg);border:0.5px solid #9FE1CB;border-radius:12px;
  padding:12px 14px;margin:14px 1rem 0;font-size:13px;color:var(--accent-strong);
  align-items:center;justify-content:space-between;gap:10px;
}
.install-banner button{
  background:var(--accent);color:#fff;border:none;padding:7px 14px;border-radius:var(--radius);
  font-size:13px;font-weight:600;flex-shrink:0;
}
footer{text-align:center;font-size:11.5px;color:var(--text-muted);padding:1.5rem 1rem .5rem;line-height:1.6}
</style>
</head>
<body>

<header>
  <div class="wrap">
    <h1>Drenagem Mineração</h1>
    <p>Dimensionamento hidráulico para mina a céu aberto</p>
  </div>
</header>

<div class="install-banner" id="installBanner">
  <span>Instale o app na tela inicial para uso offline em campo.</span>
  <button id="installBtn">Instalar</button>
</div>

<nav class="module-nav" id="moduleNav">
  <button class="mtab active" data-panel="racional">Método racional</button>
  <button class="mtab" data-panel="canal">Canal trapezoidal</button>
  <button class="mtab" data-panel="tubo">Tubo corrugado</button>
  <button class="mtab" data-panel="bacia">Bacia de sedimentação</button>
  <button class="mtab" data-panel="dissipador">Dissipador de energia</button>
  <button class="mtab" data-panel="valeta">Valeta de crista</button>
  <button class="mtab" data-panel="sarjeta">Sarjeta de pista</button>
  <button class="mtab" data-panel="relatorio">Memorial descritivo</button>
</nav>

<div class="wrap">

<!-- MÉTODO RACIONAL -->
<div id="panel-racional" class="panel active">
  <p class="section-title">Vazão de pico — Método racional</p>
  <div class="grid2">
    <div>
      <div class="card">
        <div class="ctitle">Bacia hidrográfica</div>
        <div class="field"><label>Área da bacia A (ha)</label><input type="number" id="r-A" value="50" step="1" min="0.1"></div>
        <div class="field"><label>Coeficiente de runoff C</label>
          <select id="r-C">
            <option value="0.20">0.20 — vegetação densa / solo permeável</option>
            <option value="0.35">0.35 — pastagem / solo médio</option>
            <option value="0.50">0.50 — solo compactado / mineração revegetada</option>
            <option value="0.65" selected>0.65 — área de mineração ativa</option>
            <option value="0.75">0.75 — pilha de estéril / bota-fora</option>
            <option value="0.85">0.85 — superfície rochosa exposta</option>
            <option value="0.95">0.95 — vias pavimentadas / rocha lisa</option>
          </select>
        </div>
        <div class="field"><label>Comprimento do talvegue L (m)</label><input type="number" id="r-L" value="800" step="10" min="50"></div>
        <div class="field"><label>Declividade média da bacia S (m/m)</label><input type="number" id="r-S" value="0.05" step="0.005" min="0.001"></div>
      </div>
      <div class="card">
        <div class="ctitle">Chuva de projeto</div>
        <div class="field"><label>Período de retorno Tr (anos)</label>
          <select id="r-Tr">
            <option value="5">5 anos — drenagem provisória</option>
            <option value="10" selected>10 anos — drenagem principal</option>
            <option value="25">25 anos — obras permanentes</option>
            <option value="50">50 anos — obras de grande porte</option>
          </select>
        </div>
        <div class="field"><label>Intensidade de chuva i (mm/h)</label><input type="number" id="r-i" value="80" step="5" min="10"></div>
        <p class="info">Consulte isozonas ou equações IDF regionais (DNIT/DAER-MG)</p>
      </div>
      <button class="btn primary" onclick="calcRacional()">Calcular vazão de pico</button>
    </div>
    <div>
      <p class="section-title">Resultados</p>
      <div id="racional-result"><div class="al ai">Preencha os parâmetros e calcule.</div></div>
    </div>
  </div>
</div>

<!-- CANAL TRAPEZOIDAL -->
<div id="panel-canal" class="panel">
  <p class="section-title">Canal trapezoidal — Manning</p>
  <div class="grid2">
    <div>
      <div class="card">
        <div class="ctitle">Parâmetros</div>
        <div class="field"><label>Vazão de projeto Q (m³/s)</label><input type="number" id="c-Q" value="2.5" step="0.1" min="0"></div>
        <div class="field"><label>Declividade do canal I (m/m)</label><input type="number" id="c-I" value="0.02" step="0.001" min="0.0001"></div>
        <div class="field"><label>Coeficiente de Manning n</label>
          <select id="c-n">
            <option value="0.013">Concreto liso (n=0.013)</option>
            <option value="0.016" selected>Concreto rugoso / escavado (n=0.016)</option>
            <option value="0.020">Rocha escavada (n=0.020)</option>
            <option value="0.025">Terra natural (n=0.025)</option>
            <option value="0.030">Terra com vegetação (n=0.030)</option>
            <option value="0.035">Terra muito rugosa (n=0.035)</option>
          </select>
        </div>
        <div class="field"><label>Inclinação das laterais z (H:1V)</label>
          <select id="c-z">
            <option value="0.5">0.5:1 (corte em rocha)</option>
            <option value="1.0">1:1 (terra firme)</option>
            <option value="1.5" selected>1.5:1 (recomendado)</option>
            <option value="2.0">2:1 (solo arenoso)</option>
            <option value="2.5">2.5:1 (solo muito arenoso)</option>
          </select>
        </div>
        <div class="field"><label>Folga de segurança / borda livre (m)</label><input type="number" id="c-fb" value="0.30" step="0.05" min="0.1"></div>
        <div class="field"><label>Base mínima do canal b (m)</label><input type="number" id="c-bmin" value="0.5" step="0.1" min="0.1"></div>
      </div>
      <button class="btn primary" onclick="calcCanal()">Dimensionar canal</button>
    </div>
    <div>
      <p class="section-title">Seção hidráulica ótima</p>
      <div id="canal-result"><div class="al ai">Preencha os parâmetros e dimensione.</div></div>
      <div id="canal-diagram"></div>
    </div>
  </div>
</div>

<!-- TUBO CORRUGADO -->
<div id="panel-tubo" class="panel">
  <p class="section-title">Tubo corrugado PEAD</p>
  <div class="grid2">
    <div>
      <div class="card">
        <div class="ctitle">Parâmetros</div>
        <div class="field"><label>Vazão de projeto Q (m³/s)</label><input type="number" id="t-Q" value="1.5" step="0.1" min="0"></div>
        <div class="field"><label>Declividade I (m/m)</label><input type="number" id="t-I" value="0.015" step="0.001" min="0.0001"></div>
        <div class="field"><label>Tipo de tubo</label>
          <select id="t-n">
            <option value="0.011">PEAD liso interno (n=0.011)</option>
            <option value="0.014" selected>PEAD corrugado (n=0.014)</option>
            <option value="0.016">Metálico corrugado (n=0.016)</option>
            <option value="0.024">Concreto simples (n=0.024)</option>
          </select>
        </div>
        <div class="field"><label>Grau de enchimento máximo</label>
          <select id="t-fill">
            <option value="0.75">75% — recomendado drenagem</option>
            <option value="0.80" selected>80% — padrão NBR</option>
            <option value="0.90">90% — máximo admissível</option>
          </select>
        </div>
      </div>
      <button class="btn primary" onclick="calcTubo()">Selecionar diâmetro</button>
      <div class="al ai" style="font-size:12px"><strong>Diâmetros comerciais PEAD (DN):</strong> 300 a 2000 mm</div>
    </div>
    <div>
      <p class="section-title">Resultado</p>
      <div id="tubo-result"><div class="al ai">Preencha os parâmetros e selecione.</div></div>
    </div>
  </div>
</div>

<!-- BACIA DE SEDIMENTAÇÃO -->
<div id="panel-bacia" class="panel">
  <p class="section-title">Bacia de sedimentação</p>
  <div class="grid2">
    <div>
      <div class="card">
        <div class="ctitle">Dados hidrológicos</div>
        <div class="field"><label>Vazão de projeto Q (m³/s)</label><input type="number" id="b-Q" value="1.8" step="0.1" min="0"></div>
        <div class="field"><label>Tempo de detenção mínimo td</label>
          <select id="b-td">
            <option value="10">10 min — sedimentos grossos</option>
            <option value="15" selected>15 min — padrão mineração</option>
            <option value="20">20 min — sedimentos finos</option>
            <option value="30">30 min — alta carga sólida</option>
          </select>
        </div>
      </div>
      <div class="card">
        <div class="ctitle">Dimensões e geometria</div>
        <div class="field"><label>Relação comprimento/largura (L/B)</label>
          <select id="b-lb">
            <option value="2">2:1 (mínimo)</option>
            <option value="3" selected>3:1 (recomendado)</option>
            <option value="4">4:1 (alta eficiência)</option>
            <option value="5">5:1 (máxima retenção)</option>
          </select>
        </div>
        <div class="field"><label>Profundidade útil (m)</label><input type="number" id="b-h" value="1.5" step="0.1" min="0.5" max="5"></div>
        <div class="field"><label>Borda livre (m)</label><input type="number" id="b-bl" value="0.5" step="0.05" min="0.2"></div>
        <div class="field"><label>Volume de lodo estimado por evento (m³)</label><input type="number" id="b-lodo" value="50" step="5" min="0"></div>
      </div>
      <div class="card">
        <div class="ctitle">Partícula de projeto (Stokes)</div>
        <div class="field"><label>Diâmetro mínimo a reter</label>
          <select id="b-d">
            <option value="0.05">50 μm — areia fina</option>
            <option value="0.1" selected>100 μm — areia média</option>
            <option value="0.2">200 μm — areia grossa</option>
            <option value="0.5">500 μm — cascalho fino</option>
          </select>
        </div>
        <div class="field"><label>Densidade do sólido ρs (kg/m³)</label><input type="number" id="b-rho" value="2650" step="50" min="2000" max="3500"></div>
      </div>
      <button class="btn primary" onclick="calcBacia()">Dimensionar bacia</button>
    </div>
    <div>
      <p class="section-title">Resultado</p>
      <div id="bacia-result"><div class="al ai">Preencha os parâmetros e dimensione.</div></div>
    </div>
  </div>
</div>

<!-- DISSIPADOR DE ENERGIA -->
<div id="panel-dissipador" class="panel">
  <p class="section-title">Dissipador de energia</p>
  <div class="grid2">
    <div>
      <div class="card">
        <div class="ctitle">Dados da seção de chegada</div>
        <div class="field"><label>Vazão Q (m³/s)</label><input type="number" id="d-Q" value="3.0" step="0.1" min="0.01"></div>
        <div class="field"><label>Largura do canal b (m)</label><input type="number" id="d-b" value="2.0" step="0.1" min="0.1"></div>
        <div class="field"><label>Velocidade na chegada V₁ (m/s)</label><input type="number" id="d-V1" value="6.5" step="0.1" min="0.1"></div>
        <div class="field"><label>Tipo de dissipador</label>
          <select id="d-tipo">
            <option value="bacia">Bacia de amortecimento (ressalto)</option>
            <option value="enrocamento">Enrocamento / rip-rap</option>
            <option value="degrau">Degraus em cascata</option>
          </select>
        </div>
      </div>
      <div class="card">
        <div class="ctitle">Enrocamento (quando aplicável)</div>
        <div class="field"><label>Diâmetro médio das pedras D₅₀ (m)</label><input type="number" id="d-D50" value="0.30" step="0.05" min="0.05"></div>
        <div class="field"><label>Ângulo de talude proteção θ (°)</label><input type="number" id="d-theta" value="18" step="1" min="5" max="40"></div>
      </div>
      <button class="btn primary" onclick="calcDissipador()">Dimensionar dissipador</button>
    </div>
    <div>
      <p class="section-title">Resultado</p>
      <div id="dissipador-result"><div class="al ai">Preencha os parâmetros e dimensione.</div></div>
    </div>
  </div>
</div>

<!-- VALETA DE CRISTA -->
<div id="panel-valeta" class="panel">
  <p class="section-title">Valeta de crista de talude</p>
  <div class="grid2">
    <div>
      <div class="card">
        <div class="ctitle">Parâmetros hidrológicos</div>
        <div class="field"><label>Vazão de projeto Q (m³/s)</label><input type="number" id="v-Q" value="1.2" step="0.1" min="0"></div>
        <div class="field"><label>Declividade longitudinal I (m/m)</label><input type="number" id="v-I" value="0.03" step="0.005" min="0.001"></div>
        <div class="field"><label>Coeficiente de Manning n</label>
          <select id="v-n">
            <option value="0.012">Concreto pré-moldado (n=0.012)</option>
            <option value="0.016" selected>Concreto moldado in situ (n=0.016)</option>
            <option value="0.020">Rocha escavada (n=0.020)</option>
            <option value="0.025">Terra revestida com gramínea (n=0.025)</option>
          </select>
        </div>
        <div class="field"><label>Formato da seção</label>
          <select id="v-sec">
            <option value="trapezoidal" selected>Trapezoidal (z=1:1)</option>
            <option value="triangular">Triangular (z=1.5:1)</option>
            <option value="retangular">Retangular</option>
          </select>
        </div>
        <div class="field"><label>Distância mínima da crista (m)</label><input type="number" id="v-dist" value="2.0" step="0.5" min="1"></div>
      </div>
      <div class="card">
        <div class="ctitle">Altura do talude</div>
        <div class="field"><label>Altura do talude H_tal (m)</label><input type="number" id="v-Htal" value="15" step="1" min="1"></div>
        <div class="field"><label>Inclinação do talude (H:V)</label>
          <select id="v-italude">
            <option value="1.5">1.5:1 (íngreme)</option>
            <option value="2" selected>2:1 (padrão)</option>
            <option value="3">3:1 (suave)</option>
          </select>
        </div>
      </div>
      <button class="btn primary" onclick="calcValeta()">Dimensionar valeta</button>
    </div>
    <div>
      <p class="section-title">Resultado</p>
      <div id="valeta-result"><div class="al ai">Preencha os parâmetros e dimensione.</div></div>
    </div>
  </div>
</div>

<!-- SARJETA DE PISTA -->
<div id="panel-sarjeta" class="panel">
  <p class="section-title">Sarjeta de pista de acesso</p>
  <div class="grid2">
    <div>
      <div class="card">
        <div class="ctitle">Dados da pista</div>
        <div class="field"><label>Largura da pista W (m)</label><input type="number" id="s-W" value="14" step="0.5" min="4"></div>
        <div class="field"><label>Declividade transversal e (%)</label><input type="number" id="s-e" value="3" step="0.5" min="1" max="10"></div>
        <div class="field"><label>Declividade longitudinal S (%)</label><input type="number" id="s-S" value="8" step="0.5" min="0.5"></div>
        <div class="field"><label>Comprimento entre saídas L (m)</label><input type="number" id="s-L" value="60" step="5" min="10"></div>
        <div class="field"><label>Intensidade de chuva i (mm/h)</label><input type="number" id="s-i" value="80" step="5" min="10"></div>
        <div class="field"><label>Coef. runoff pista C</label>
          <select id="s-C">
            <option value="0.70">0.70 — cascalho compactado</option>
            <option value="0.80" selected>0.80 — solo compactado / base</option>
            <option value="0.90">0.90 — pavimento asfáltico</option>
          </select>
        </div>
      </div>
      <div class="card">
        <div class="ctitle">Sarjeta triangular</div>
        <div class="field"><label>Coeficiente Manning sarjeta n</label>
          <select id="s-n">
            <option value="0.013" selected>Concreto (n=0.013)</option>
            <option value="0.016">Pedra argamassada (n=0.016)</option>
          </select>
        </div>
        <div class="field"><label>Inclinação face interna Z₁ (H:1V)</label><input type="number" id="s-z1" value="0.5" step="0.1" min="0.1" max="2"></div>
        <div class="field"><label>Inclinação face externa Z₂ (H:1V)</label><input type="number" id="s-z2" value="12" step="0.5" min="1"></div>
      </div>
      <button class="btn primary" onclick="calcSarjeta()">Dimensionar sarjeta</button>
    </div>
    <div>
      <p class="section-title">Resultado</p>
      <div id="sarjeta-result"><div class="al ai">Preencha os parâmetros e dimensione.</div></div>
    </div>
  </div>
</div>

